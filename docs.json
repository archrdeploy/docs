{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Archr",
  "theme": "mint",
  "colors": {
    "primary": "#3f4d00",
    "light":   "#ccff00",
    "dark":    "#3f4d00"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "family": "Space Grotesk"
  },
  "logo": {
    "light": "/logo/logo.png",
    "dark":  "/logo/logo-inverted.png"
  },
  "favicon": "/logo/favicon.png",
  "seo": {
    "metatags": {
      "og:title":       "Archr Docs",
      "og:description": "A self-serve token launchpad on Robinhood Chain with burned Uniswap V4 liquidity, creator rewards paid in ETH, and a time-locked airdrop program for ARCHR holders.",
      "twitter:card":   "summary_large_image"
    }
  },
  "navbar": {
    "links": [
      { "label": "X",   "href": "https://x.com/archrdeploy" },
      { "label": "App", "href": "https://archr.win" }
    ]
  },
  "footer": {
    "socials": {
      "x":       "https://x.com/archrdeploy",
      "website": "https://archr.win"
    }
  },
  "navigation": {
    "groups": [
      { "group": "Get started", "pages": ["introduction", "getting-started/wallet-setup", "getting-started/first-launch-site", "getting-started/first-launch-reddit", "getting-started/first-launch-twitter"] },
      { "group": "Launch",      "pages": ["launch/overview", "launch/dev-buy", "launch/airdrop-mode", "launch/creator-fees", "launch/tickers", "launch/migrations"] },
      { "group": "Trade",       "pages": ["trade/overview"] },
      { "group": "Earn",        "pages": ["earn/holder-rewards", "earn/archr-flywheel"] },
      { "group": "Reference",   "pages": ["reference/faq", "reference/glossary", "reference/risks", "reference/security", "network/contracts"] },
      { "group": "Developer",   "pages": ["developer/token-list"] }
    ]
  }
}
